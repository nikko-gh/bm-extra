{
    "manifest_version": 3,
    "name": "bm-extra",
    "version": "1.3.7",
    "description": "BattleMetrics Extension that aims to enhance your experience with quality of life features.",
    "author": "FlQyD",
    "content_scripts": [
        {
            "matches": [
                "https://www.battlemetrics.com/*"
            ],
            "run_at": "document_start",
            "js": [
                "./main.js"
            ],
            "css": [
                "./assets/style/main.css",
                "./assets/style/settings.css",
                "./assets/style/sidebar.css",
                "./assets/style/evasionChecker.css"
            ]
        }
    ],
    "background": {
        "service_worker": "./bg/bg.js",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/img/*.png",
                "modules/*.js"
            ],
            "matches": [
                "*://www.battlemetrics.com/*",
                "*://battlemetrics.com/*"
            ]
        }
    ],
    "host_permissions": [
        "https://api.battlemetrics.com/*",
        "https://api.steampowered.com/*",
        "https://player-insight.flqyd.dev/*",
        "https://rust-api.facepunch.com/*",
        "https://proxycheck.io/*"
    ],
    "permissions": [
        "storage",
        "downloads"
    ]
}